{
  "manifest_version": 3,
  "name": "Obsidian Note Exporter",
  "version": "1.0.0",
  "description": "Save and export notes through the local Obsidian Note Exporter Flask server.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Obsidian Note Exporter"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ]
}
